  "author": "BoostU Agency <nick@boostu.be> (https://boostu.be)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/boostuagency/boostu-teamleader-mcp.git"
  },
  "homepage": "https://github.com/boostuagency/boostu-teamleader-mcp#readme",
  "bugs": {
    "url": "https://github.com/boostuagency/boostu-teamleader-mcp/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.5.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.9"
  }
