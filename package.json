{
  "name": "boostu-teamleader-mcp",
  "version": "2.1.0",
  "description": "BoostU MCP server for Teamleader Focus CRM — contacts, companies, deals, quotations, invoices, products, projects, and more.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "boostu-teamleader-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
