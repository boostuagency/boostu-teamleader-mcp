# BoostU Teamleader MCP — copy to .env and fill in (see docs/AUTHENTICATION.md)
# Required: OAuth2 credentials from your Teamleader Marketplace integration
TEAMLEADER_CLIENT_ID=
TEAMLEADER_CLIENT_SECRET=
TEAMLEADER_REFRESH_TOKEN=

# Optional: file path where the rotating refresh token is persisted (source of truth).
# Recommended in production — Teamleader rotates the refresh token on every refresh.
TEAMLEADER_TOKEN_STORE=.teamleader-token

# Optional: restrict which tool groups are exposed (comma-separated; unset = all).
# Group keys: contacts,companies,deals,tasks,events,invoices,quotations,products,
# reference,org,customFields,creditNotes,subscriptions,projects,timeTracking,
# activities,tickets,tags,notes,files,webhooks
# TEAMLEADER_TOOLS=deals,quotations,products,invoices
